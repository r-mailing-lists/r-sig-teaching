>> >   geom_line(aes(x = date, y = Well2, colour = "Well2")) +
>> >   geom_point(aes(x = date, y = Well1, colour = "Well1", shape = group)) +
>> >   geom_point(aes(x = date, y = Well2, colour = "Well2", shape = group))
